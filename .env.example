# Azure DevOps Personal Access Token (required for ADO integration and bug filing)
ADO_PAT=

# Scanner credentials in user:pass format (optional — used for authenticated scans)
A11Y_SCANNER_CREDENTIALS=

# OpenAI API key (optional — required for LLM-based edge case generation with --ai-generate)
OPENAI_API_KEY=

# Azure OpenAI endpoint URL (optional — alternative to OPENAI_API_KEY for Azure OpenAI service)
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key (optional — used with AZURE_OPENAI_ENDPOINT)
AZURE_OPENAI_API_KEY=
